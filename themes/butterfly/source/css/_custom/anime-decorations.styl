// 二次元装饰元素样式
// Anime Decoration Elements

// ========================
// 樱花飘落效果
// ========================
@keyframes sakura-fall
  0%
    transform: translateY(0) rotateZ(0deg)
    opacity: 1
  75%
    opacity: 1
  100%
    transform: translateY(100vh) rotateZ(360deg)
    opacity: 0

@keyframes sakura-sway
  0%, 100%
    transform: translateX(0)
  25%
    transform: translateX(80px)
  75%
    transform: translateX(-80px)

.sakura-container
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100vh
  pointer-events: none
  z-index: 1
  overflow: hidden

.sakura
  position: absolute
  width: 20px
  height: 20px
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="20" r="3" fill="%23FFB6C1"/><circle cx="30" cy="45" r="3" fill="%23FFB6C1"/><circle cx="70" cy="45" r="3" fill="%23FFB6C1"/><circle cx="20" cy="70" r="3" fill="%23FFB6C1"/><circle cx="80" cy="70" r="3" fill="%23FFB6C1"/><circle cx="50" cy="50" r="5" fill="%23FF69B4"/></svg>') no-repeat center
  background-size: contain
  animation: sakura-fall 10s linear forwards, sakura-sway 3s ease-in-out infinite

// ========================
// 二次元徽章
// ========================
.anime-badge
  display: inline-block
  background: linear-gradient(135deg, #FF69B4, #9370DB)
  color: white
  padding: 8px 16px
  border-radius: 20px
  font-size: 12px
  font-weight: bold
  box-shadow: 0 2px 8px rgba(255, 105, 180, 0.3)
  position: relative
  overflow: hidden

  &::before
    content: '✨'
    margin-right: 6px
    animation: sparkle 1.5s ease-in-out infinite

// ========================
// 二次元分割线
// ========================
.anime-divider
  position: relative
  height: 3px
  background: linear-gradient(90deg, transparent, #FF69B4, #9370DB, #00CED1, transparent)
  margin: 30px 0
  border-radius: 2px
  box-shadow: 0 2px 8px rgba(255, 105, 180, 0.2)

  &::before, &::after
    content: '◆'
    position: absolute
    top: 50%
    transform: translateY(-50%)
    color: #FF69B4
    font-size: 16px

  &::before
    left: -30px

  &::after
    right: -30px

// ========================
// 二次元提示框
// ========================
.anime-tip
  background: rgba(255, 255, 255, 0.95)
  border-left: 4px solid #FF69B4
  border-radius: 8px
  padding: 15px 20px
  margin: 20px 0
  box-shadow: 0 4px 12px rgba(255, 105, 180, 0.2)
  position: relative

  &.warning
    border-left-color: #FFA500
    background: rgba(255, 165, 0, 0.05)

  &.info
    border-left-color: #00CED1
    background: rgba(0, 206, 209, 0.05)

  &.success
    border-left-color: #00FF00
    background: rgba(0, 255, 0, 0.05)

// ========================
// 二次元卡片
// ========================
.anime-card
  background: rgba(255, 255, 255, 0.9)
  backdrop-filter: blur(10px)
  border-radius: 12px
  padding: 20px
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1)
  border: 1px solid rgba(255, 105, 180, 0.2)
  transition: all 0.3s ease
  position: relative
  overflow: hidden

  &::before
    content: ''
    position: absolute
    top: 0
    left: 0
    right: 0
    height: 3px
    background: linear-gradient(90deg, #FF69B4, #9370DB, #00CED1)
    border-radius: 2px

  &:hover
    transform: translateY(-5px)
    box-shadow: 0 12px 32px rgba(255, 105, 180, 0.3)
    border-color: rgba(255, 105, 180, 0.5)

// ========================
// 闪烁效果
// ========================
@keyframes sparkle
  0%, 100%
    opacity: 1
    transform: scale(1)
  50%
    opacity: 0.5
    transform: scale(0.8)

@keyframes glow
  0%, 100%
    text-shadow: 0 0 5px rgba(255, 105, 180, 0.5)
  50%
    text-shadow: 0 0 15px rgba(255, 105, 180, 0.8)

.sparkle
  animation: sparkle 1.5s ease-in-out infinite

.glow
  animation: glow 2s ease-in-out infinite

// ========================
// 二次元标题样式
// ========================
.anime-title
  position: relative
  padding-left: 25px
  color: #2C2C54

  &::before
    content: '✦'
    position: absolute
    left: 0
    color: #FF69B4
    font-size: 18px
    animation: rotate 3s linear infinite

  &::after
    content: ''
    position: absolute
    bottom: -8px
    left: 0
    width: 100%
    height: 2px
    background: linear-gradient(90deg, #FF69B4, #9370DB, transparent)
    border-radius: 2px

@keyframes rotate
  from
    transform: rotate(0deg)
  to
    transform: rotate(360deg)

// ========================
// 渐变文字
// ========================
.anime-gradient-text
  background: linear-gradient(135deg, #FF69B4, #9370DB, #00CED1)
  -webkit-background-clip: text
  -webkit-text-fill-color: transparent
  background-clip: text
  font-weight: bold
  font-size: 1.2em

// ========================
// 二次元脚注
// ========================
.anime-footnote
  font-size: 12px
  color: #9370DB
  font-style: italic
  border-left: 2px solid #FFB6C1
  padding-left: 10px
  margin: 10px 0

// ========================
// 二次元代码行号美化
// ========================
.line-numbers
  background: linear-gradient(180deg, rgba(255, 105, 180, 0.1), rgba(147, 112, 219, 0.1))
  border-right: 2px solid #FFB6C1
  padding-right: 15px
  margin-right: 15px
  color: #9370DB
