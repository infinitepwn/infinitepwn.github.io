// ========================
// 高级装饰元素 Premium Decorations
// 设计理念：精致、不突兀、提升整体气质
// ========================

// 色彩变量
$gradient-primary = linear-gradient(135deg, #667eea 0%, #764ba2 100%)
$gradient-accent = linear-gradient(120deg, #a8edea 0%, #fed6e3 100%)

// ========================
// 1. 标题装饰线
// ========================
.post-title::before,
.widget-title::before
  content: '✨'
  margin-right: 8px
  background: $gradient-primary
  background-clip: text
  -webkit-background-clip: text
  -webkit-text-fill-color: transparent

// ========================
// 2. 分割线美化
// ========================
hr
  border: none
  height: 2px
  background: $gradient-primary
  margin: 24px 0
  border-radius: 1px
  opacity: 0.6

// ========================
// 3. 文章摘要装饰
// ========================
.post-excerpt
  position: relative
  padding-left: 12px
  
  &::before
    content: ''
    position: absolute
    left: 0
    top: 0
    bottom: 0
    width: 3px
    background: $gradient-primary
    border-radius: 2px

// ========================
// 4. 重点文字强调
// ========================
strong, b
  background: rgba(102, 126, 234, 0.1)
  padding: 2px 4px
  border-radius: 3px
  font-weight: 700

// ========================
// 5. 引用块装饰
// ========================
blockquote
  border-left: 4px solid $gradient-primary
  padding-left: 16px
  margin-left: 0
  color: #7f8c8d
  font-style: italic
  background: rgba(102, 126, 234, 0.05)
  padding: 12px 16px
  border-radius: 6px

// ========================
// 6. 列表美化
// ========================
ul, ol
  li
    position: relative
    margin-bottom: 8px
    
    &::marker
      color: #667eea
      font-weight: 700

// ========================
// 7. 表格优化
// ========================
table
  border-collapse: collapse
  width: 100%
  margin: 16px 0
  
  thead
    background: rgba(102, 126, 234, 0.05)
    
    th
      padding: 12px
      border-bottom: 2px solid #667eea
      color: #667eea
      font-weight: 700
      text-align: left
  
  tbody
    tr
      border-bottom: 1px solid rgba(0, 0, 0, 0.05)
      transition: background 0.2s ease
      
      &:hover
        background: rgba(102, 126, 234, 0.05)
    
    td
      padding: 12px

// ========================
// 8. 提示框装饰
// ========================
.note, .info, .warning, .danger
  border-left: 4px solid
  padding: 12px 16px
  border-radius: 6px
  margin: 12px 0
  background-size: 20px 20px
  
  &.info
    border-color: #667eea
    background: rgba(102, 126, 234, 0.05)
    color: #667eea
  
  &.warning
    border-color: #f39c12
    background: rgba(243, 156, 18, 0.05)
    color: #e67e22
  
  &.danger
    border-color: #e74c3c
    background: rgba(231, 76, 60, 0.05)
    color: #e74c3c

// ========================
// 9. 返回顶部按钮
// ========================
#scroll-top
  background: $gradient-primary
  border-radius: 50%
  width: 50px
  height: 50px
  box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4)
  
  &:hover
    transform: translateY(-4px)
    box-shadow: 0 12px 32px rgba(102, 126, 234, 0.6)

// ========================
// 10. 行内代码装饰
// ========================
code
  font-family: 'Courier New', monospace
  letter-spacing: 0.3px

// ========================
// 11. 脚注装饰
// ========================
.footnote
  font-size: 0.9rem
  color: $text-secondary
  padding: 8px 12px
  background: rgba(0, 0, 0, 0.02)
  border-left: 2px solid $gradient-primary
  margin-top: 16px

// ========================
// 12. 装饰角标
// ========================
.post-meta::before
  content: '📝'
  margin-right: 6px

.post-category::before
  content: '🏷️'
  margin-right: 4px

.post-date::before
  content: '📅'
  margin-right: 4px

// ========================
// 13. 平滑过渡
// ========================
.fade-in
  animation: fadeIn 0.5s ease-in
  
@keyframes fadeIn
  from
    opacity: 0
    transform: translateY(10px)
  to
    opacity: 1
    transform: translateY(0)

// ========================
// 14. 脉冲效果
// ========================
.pulse
  animation: pulse 2s infinite
  
@keyframes pulse
  0%, 100%
    opacity: 1
  50%
    opacity: 0.7
