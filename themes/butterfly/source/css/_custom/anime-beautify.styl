// ========================
// 高级二次元主题 Premium Anime Theme
// 设计理念：优雅、现代、精致的二次元风格
// ========================

// 色彩系统 - 优雅的渐变色盘
$primary-gradient = linear-gradient(135deg, #667eea 0%, #764ba2 100%)
$accent-gradient = linear-gradient(120deg, #a8edea 0%, #fed6e3 100%)
$text-primary = #2c3e50
$text-secondary = #7f8c8d
$border-light = rgba(0, 0, 0, 0.05)
$shadow-sm = 0 4px 12px rgba(0, 0, 0, 0.08)
$shadow-md = 0 8px 24px rgba(0, 0, 0, 0.12)
$shadow-lg = 0 16px 40px rgba(0, 0, 0, 0.15)

// ========================
// 1. 全局优化
// ========================
*
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1)

html, body
  background: #f8f9fa
  color: $text-primary
  font-weight: 500
  letter-spacing: 0.3px

// ========================
// 2. 导航栏 - 简洁现代设计
// ========================
#nav, nav.navbar
  background: rgba(255, 255, 255, 0.98)
  box-shadow: $shadow-md
  border: none
  border-bottom: 1px solid $border-light
  
  .nav-item a
    position: relative
    color: $text-primary
    font-weight: 600
    letter-spacing: 0.5px
    overflow: hidden
    
    &::before
      content: ''
      position: absolute
      bottom: 0
      left: -100%
      width: 100%
      height: 2px
      background: $primary-gradient
      transition: left 0.3s ease
    
    &:hover::before
      left: 0

// ========================
// 3. 文章卡片 - 高级卡片设计
// ========================
.post-card, article.post, .post
  background: white
  border-radius: 12px
  box-shadow: $shadow-sm
  border: 1px solid $border-light
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1)
  overflow: hidden
  
  &:hover
    box-shadow: $shadow-lg
    transform: translateY(-4px)
    border-color: rgba(102, 126, 234, 0.2)

.post-title
  background: $primary-gradient
  background-clip: text
  -webkit-background-clip: text
  -webkit-text-fill-color: transparent
  font-size: 1.8rem
  font-weight: 700
  letter-spacing: -0.5px

// ========================
// 4. 代码块 - 现代化设计
// ========================
pre, code
  background: #1e1e1e
  color: #e0e0e0
  border-radius: 8px
  font-family: 'Monaco', 'Courier New', monospace
  letter-spacing: 0.2px

.hljs
  background: #1e1e1e
  border-radius: 8px
  padding: 16px
  overflow-x: auto
  
  &:hover
    box-shadow: $shadow-md

code
  padding: 2px 6px
  background: rgba(0, 0, 0, 0.08)
  border-radius: 4px

// ========================
// 5. 侧边栏卡片
// ========================
.widget-wrap .widget
  background: white
  border-radius: 12px
  box-shadow: $shadow-sm
  padding: 16px
  margin-bottom: 16px
  border: 1px solid $border-light
  
  .widget-title
    color: $text-primary
    font-weight: 700
    font-size: 1.1rem
    margin-bottom: 12px
    padding-bottom: 8px
    border-bottom: 2px solid $primary-gradient

// ========================
// 6. 标签和分类
// ========================
.tag-cloud a, .category a
  display: inline-block
  padding: 6px 12px
  margin: 4px
  background: rgba(102, 126, 234, 0.1)
  color: #667eea
  border-radius: 20px
  transition: all 0.3s ease
  font-size: 0.9rem
  
  &:hover
    background: $primary-gradient
    color: white
    transform: scale(1.05)

// ========================
// 7. 分页按钮
// ========================
.pagination .page-number, 
.pagination .prev, 
.pagination .next
  background: white
  border: 1px solid $border-light
  border-radius: 6px
  color: $text-primary
  transition: all 0.3s ease
  
  &:hover, &.current
    background: $primary-gradient
    color: white
    border-color: $primary-gradient

// ========================
// 8. 链接优化
// ========================
a
  color: #667eea
  text-decoration: none
  position: relative
  
  &:hover
    color: #764ba2

// ========================
// 9. 顶部封面
// ========================
.banner
  background-size: cover
  background-position: center
  background-attachment: fixed
  position: relative
  
  &::before
    content: ''
    position: absolute
    top: 0
    left: 0
    right: 0
    bottom: 0
    background: rgba(0, 0, 0, 0.3)
    z-index: 1

// ========================
// 10. 页脚优化
// ========================
#footer
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05))
  border-top: 1px solid $border-light
  color: $text-secondary
  
  a
    color: #667eea
    
    &:hover
      color: #764ba2

// ========================
// 11. 滚动条美化
// ========================
::-webkit-scrollbar
  width: 8px
  height: 8px

::-webkit-scrollbar-track
  background: #f8f9fa

::-webkit-scrollbar-thumb
  background: $primary-gradient
  border-radius: 4px
  
  &:hover
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)
